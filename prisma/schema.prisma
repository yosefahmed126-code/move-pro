generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Patient {
  id         Int       @id @default(autoincrement())
  code       String    @unique
  name       String
  gender     String?
  birthDate  DateTime?
  mobile     String
  mobile2    String?
  email      String?
  nationalId String?
  address    String?
  therapist  String?

  branchId Int
  branch   Branch @relation(fields: [branchId], references: [id])

  packageId Int?
  package   Package? @relation(fields: [packageId], references: [id])

  remaining Int    @default(0)
  status    String @default("Active")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
@@index([branchId])
@@index([packageId])
@@index([status])

}

model Package {
  id             Int    @id @default(autoincrement())
  name           String @unique
  sessions       Int
  price          Float
  allowedExcuses Int    @default(0)
  status         String @default("Active")

  patients Patient[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
@@index([status])
}

model Branch {
  id     Int    @id @default(autoincrement())
  name   String @unique
  status String @default("Active")

  patients Patient[]
  users    User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Role {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?

  users User[]
}

model User {
  id Int @id @default(autoincrement())

  fullName String
  username String @unique
  password String

  phone String?
  email String?

  status String @default("Active")

  roleId Int
  role   Role @relation(fields: [roleId], references: [id])

  branchId Int?
  branch   Branch? @relation(fields: [branchId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
