generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Patient {
  id   Int    @id @default(autoincrement())
  code String @unique

  name      String
  gender    String?
  birthDate DateTime?

  mobile  String
  mobile2 String?

  email      String?
  nationalId String?
  address    String?

  therapistId Int?
  therapist   Therapist? @relation(fields: [therapistId], references: [id])

  branchId Int
  branch   Branch @relation(fields: [branchId], references: [id])

  packageId Int?
  package   Package? @relation(fields: [packageId], references: [id])

  remaining Int    @default(0)
  status    String @default("Active")

  appointments Appointment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([branchId])
  @@index([packageId])
  @@index([therapistId])
  @@index([status])
}

model Therapist {
  id Int @id @default(autoincrement())

  name String

  mobile String?
  email  String?

  specialty String?
  notes     String?

  branchId Int
  branch   Branch @relation(fields: [branchId], references: [id])

  patients Patient[]

  appointments Appointment[]

  status String @default("Active")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([branchId])
  @@index([status])
}

model Appointment {
  id Int @id @default(autoincrement())

  patientId Int
  patient Patient @relation(fields: [patientId], references: [id])

  therapistId Int
  therapist Therapist @relation(fields: [therapistId], references: [id])

  branchId Int
  branch Branch @relation(fields: [branchId], references: [id])

  date DateTime

  startTime DateTime
  endTime DateTime

  duration Int @default(40)

  status AppointmentStatus @default(BOOKED)

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum AppointmentStatus {
  BOOKED
  CHECKED_IN
  EXCUSED
  MISSED
  CANCELLED
}

model Package {
  id Int @id @default(autoincrement())

  name String @unique

  sessions Int
  price    Float

  allowedExcuses Int @default(0)

  status String @default("Active")

  patients Patient[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

model Branch {
  id Int @id @default(autoincrement())

  name String @unique

  status String @default("Active")

  patients Patient[]

  therapists Therapist[]

  appointments Appointment[]

  users User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

model Role {
  id Int @id @default(autoincrement())

  name String @unique

  description String?

  users User[]
}

model User {
  id Int @id @default(autoincrement())

  fullName String

  username String @unique

  password String

  phone String?
  email String?

  status String @default("Active")

  roleId Int
  role   Role @relation(fields: [roleId], references: [id])

  branchId Int?
  branch   Branch? @relation(fields: [branchId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([roleId])
  @@index([branchId])
  @@index([status])
}
