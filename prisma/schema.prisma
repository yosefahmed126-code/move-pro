generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Patient {
  id         Int      @id @default(autoincrement())
  code       String   @unique
  name       String
  gender     String?
  birthDate  DateTime?
  mobile     String
  mobile2    String?
  email      String?
  nationalId String?
  address    String?
  therapist  String?
 branchId Int
branch Branch @relation(fields: [branchId], references: [id])
  package    String?
  remaining  Int      @default(0)
  status     String   @default("Active")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
model Branch {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  status    String   @default("Active")

  patients  Patient[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}